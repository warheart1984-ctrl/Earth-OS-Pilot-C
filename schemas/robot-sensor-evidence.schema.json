{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://cse.constitutional.standards/robot-sensor-evidence/v1.0",
  "title": "Constitutional Robot Sensor Evidence v1.0",
  "type": "object",
  "properties": {
    "evidence_id": { "type": "string" },
    "sensor_id": { "type": "string" },
    "robot_id": { "type": "string" },
    "sensor_type": { "type": "string" },
    "readings": { "type": "array" },
    "timestamp": { "type": "integer" },
    "location": { "type": "object" },
    "attestation": { "type": "string" },
    "chain_of_custody": { "type": "array", "items": { "type": "string" } }
  },
  "required": ["evidence_id", "sensor_id", "robot_id", "sensor_type", "readings", "timestamp", "attestation"]
}
